[
  {
    "id": "euler",
    "name": "Euler number",
    "symbol": "\\text{Eu}",
    "aliases": [],
    "numer": {
      "quantities": ["pressure-difference"],
      "exponents": [1],
      "label": "static pressure difference"
    },
    "denom": {
      "quantities": ["density", "velocity"],
      "exponents": [1, 2],
      "label": "dynamic pressure"
    },
    "regimes": {
      "duct flow": {
        "thresholds": [0, 0.7, 0.9, 1.1, null],
        "labels": ["high inertia", "real-world", "ideal", "friction dominant"],
        "descriptions": [
          "Inertial forces dominate. Pressure drop is small compared to dynamic pressure.",
          "Typical for many engineering applications. Both inertial and frictional effects are important.",
          "Idealized limit where inertial and frictional effects are balanced. Useful for theoretical analysis.",
          "Frictional forces dominate. Pressure drop is large compared to dynamic pressure."
        ]
      }
    },
    "domain": "fluid-mechanics",
    "see_also": ["reynolds", "froude"]
  },
  {
